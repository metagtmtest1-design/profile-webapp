{
  "name": "portfolio-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:workers": "vitest --config vite.workers.config.ts",
    "test:workers:watch": "vitest --config vite.workers.config.ts --watch",
    "lint": "tsc --noEmit",
    "migrate:local": "wrangler d1 migrations apply portfolio-db --local",
    "migrate:preview": "wrangler d1 migrations apply portfolio-db-preview --remote",
    "migrate:alpha": "wrangler d1 migrations apply portfolio-db-alpha --remote",
    "migrate:prod": "wrangler d1 migrations apply portfolio-db --remote"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.19",
    "@cloudflare/workers-types": "^4.20240614.0",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.3",
    "jsdom": "^24.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.8",
    "wrangler": "^3.78.0"
  }
}
